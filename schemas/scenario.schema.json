{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dephy.local/schemas/scenario.schema.json",
  "title": "Dephy Motion Scenario",
  "type": "object",
  "required": ["scenario_id", "goal", "io_sample_period_ms", "render_period_ms", "script"],
  "properties": {
    "scenario_id": { "type": "string" },
    "goal": { "type": "string", "enum": ["run_straight", "turn_left", "turn_right", "slow_down", "speed_up"] },
    "io_sample_period_ms": { "type": "integer", "minimum": 1 },
    "render_period_ms": { "type": "integer", "minimum": 1 },
    "script": { "type": "string" },
    "pass_criteria": {
      "type": "object",
      "properties": {
        "max_joint_error": { "type": "number", "minimum": 0 },
        "max_foot_slip": { "type": "number", "minimum": 0 },
        "min_confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}

